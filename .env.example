SERVICE_HOST = "0.0.0.0"
SERVICE_PORT = 62050

XRAY_API_HOST = "0.0.0.0"
XRAY_API_PORT = 62051
# XRAY_EXECUTABLE_PATH = /usr/local/bin/xray
# XRAY_ASSETS_PATH = /usr/local/share/xray

SSL_CERT_FILE = /var/lib/marzban-node/ssl_cert.pem
SSL_KEY_FILE = /var/lib/marzban-node/ssl_key.pem
SSL_CLIENT_CERT_FILE = /var/lib/marzban-node/ssl_client_cert.pem

CERTIFICATES_DIR = /var/lib/marzban-node/certificates
ACME_SH_PATH = /usr/local/bin/acme.sh
ACME_TIMEOUT = 300
ACME_RENEW_BEFORE_DAYS = 30

### can be rest or rpyc
# SERVICE_PROTOCOL = rpyc

### for developers
# DEBUG = false

### Select Specific Inbounds
# INBOUNDS = "VLESS TCP REALITY, VMESS TCP NO TLS"
